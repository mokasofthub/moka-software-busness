    {
      "id": 100,
      "title": "Uptime \u2014 Portfolio & Jenkins",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "avg(avg_over_time(probe_success{job=\"mokasoftwarebusness-uptime\"}[6h])) * 100",
          "instant": true,
          "range": false,
          "legendFormat": "Portfolio Site"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-prom"
          },
          "expr": "avg(avg_over_time(probe_success{job=\"jenkins-uptime\"}[6h])) * 100",
          "instant": true,
          "range": false,
          "legendFormat": "Jenkins"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
